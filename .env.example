# Required for live GLM-backed incident generation, tool responses, and reports.
GLM_API_KEY=

# Defaults used by the demo.
GLM_MODEL=glm-5.1
GLM_TOOL_MODEL=glm-5-turbo
GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Optional faster hosted graph orchestration provider.
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
